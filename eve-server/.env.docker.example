# Docker 开发环境示例
# 用法：复制为 .env.docker 后，把下面的占位值改成真实值。

# 如果容器直连云端数据库，请填写云端数据库主机名，不要使用 localhost。
# 示例：postgresql+asyncpg://eve_admin:your_password@db.example.com:5432/eve_db
# 如果容器需要访问宿主机上的 SSH 隧道，再把主机改成 host.docker.internal。
DATABASE_URL=postgresql+asyncpg://eve_admin:your_password@your-cloud-db-host:5432/eve_db

ESI_CLIENT_ID=your_esi_client_id
CLIENT_SECRET=your_client_secret
ESI_CALLBACK_URL=http://localhost:8000/api/v1/auth/callback
SECRET_KEY=replace_with_a_real_secret_key
